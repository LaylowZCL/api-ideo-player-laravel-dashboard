# Production environment variables for fernandozucula.com
# Copy this to .env on the server and update all ALTERAR_ values

APP_NAME="Video Player Dashboard"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://fernandozucula.com

# Generate with: php artisan key:generate --show
APP_KEY=base64:GENERATE_NEW_KEY_HERE

VIDEO_API_BASE_URL=https://fernandozucula.com/api
VIDEO_API_ENDPOINT=https://fernandozucula.com/api/videos

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fernandozucula_video
DB_USERNAME=fernandozucula_user
DB_PASSWORD="GENERATE_STRONG_PASSWORD_HERE"

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.fernandozucula.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@fernandozucula.com
MAIL_PASSWORD="GENERATE_SMTP_PASSWORD_HERE"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@fernandozucula.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Authentication settings
BM_DASHBOARD_AUTH=true

# Active Directory (DISABLED)
AD_ENABLED=false
AD_ALLOW_LOCAL_FALLBACK=true
AD_HOST=localhost
AD_PORT=636
AD_USE_SSL=true
AD_USE_TLS=false
AD_REQUIRE_SSL=true
AD_BASE_DN=
AD_COMPUTER_BASE_DN=
AD_BIND_DN=
AD_BIND_PASSWORD=
AD_USER_ATTRIBUTE=sAMAccountName
AD_GROUP_ATTRIBUTE=memberOf
AD_GROUP_SUPER_ADMIN=
AD_GROUP_ADMIN=
AD_GROUP_MANAGER=
AD_SYNC_CLIENT_GROUPS=false
AD_GROUP_SOURCE=json
AD_GROUP_JSON_PATH=storage/app/ad/ad-groups.json
AD_MOCK_USERS_PATH=storage/app/ad/mock-users.json
AD_SSO_ENABLED=false
AD_SSO_HEADER=REMOTE_USER
AD_MOCK_ONLY=false

# Targeting engine
AD_TARGET_SOURCE=json
TARGET_CACHE_ENABLED=true
TARGET_CACHE_TTL=600
TARGET_DEBUG=false

# Client authentication
CLIENT_TOKEN_ENABLED=true
CLIENT_TOKEN_HEADER=X-Client-Token

# Two-Factor Authentication
TWO_FACTOR_ENABLED=true
TWO_FACTOR_REQUIRED=true
TWO_FACTOR_API_ENABLED=false
TWO_FACTOR_API_SECRET=

# Client API security
VIDEO_CLIENT_API_KEY="GENERATE_STRONG_API_KEY_HERE"
VIDEO_CLIENT_ALLOWED_ORIGINS="127.0.0.1,localhost,fernandozucula.com,www.fernandozucula.com"

# Laravel app security
APP_API_KEY="GENERATE_STRONG_APP_KEY_HERE"
APP_CLIENT_ID="ELECTRON_VIDEO_PLAYER"

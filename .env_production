APP_NAME="Banco Moc Video Scheduler"
APP_ENV=production
APP_KEY=base64:GERAR_COM_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=https://video-dashboard.bancomoc.local

VIDEO_API_BASE_URL=https://video-dashboard.bancomoc.local/api
VIDEO_API_ENDPOINT=https://video-dashboard.bancomoc.local/api/videos

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=10.10.10.20
DB_PORT=3306
DB_DATABASE=bm_popup_scheduler_prod
DB_USERNAME=bm_popup_scheduler_user
DB_PASSWORD="ALTERAR_PARA_PASSWORD_FORTE_PRODUCAO"

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@bancomoc.mz
MAIL_PASSWORD="ALTERAR_PARA_PASSWORD_SMTP_REAL"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@bancomoc.mz
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# =========================
# ACTIVE DIRECTORY
# =========================
AD_ENABLED=true
AD_ALLOW_LOCAL_FALLBACK=false

AD_HOST=dc01.bancomoc.local
AD_PORT=636
AD_USE_SSL=true
AD_USE_TLS=false
AD_REQUIRE_SSL=true

AD_BASE_DN=DC=bancomoc,DC=local
AD_COMPUTER_BASE_DN=OU=Computadores,DC=bancomoc,DC=local

AD_BIND_DN="CN=svc-ldap-video,OU=Service Accounts,DC=bancomoc,DC=local"
AD_BIND_PASSWORD="ALTERAR_PARA_PASSWORD_DA_CONTA_LDAP"

AD_USER_ATTRIBUTE=sAMAccountName
AD_GROUP_ATTRIBUTE=memberOf

AD_GROUP_SUPER_ADMIN=GRP_ROLE_SUPER_ADMIN
AD_GROUP_ADMIN=GRP_ROLE_ADMIN
AD_GROUP_MANAGER=GRP_ROLE_MANAGER

AD_SYNC_CLIENT_GROUPS=true
AD_GROUP_SOURCE=json
AD_GROUP_JSON_PATH=storage/app/ad/ad-groups.json
AD_MOCK_USERS_PATH=storage/app/ad/mock-users.json
AD_SSO_ENABLED=false
AD_SSO_HEADER=REMOTE_USER
AD_MOCK_ONLY=false

# =========================
# DASHBOARD / AUTH
# =========================
BM_DASHBOARD_AUTH=true

# =========================
# TARGETING ENGINE
# =========================
AD_TARGET_SOURCE=json
TARGET_CACHE_ENABLED=true
TARGET_CACHE_TTL=600
TARGET_DEBUG=false

# =========================
# CLIENT AUTH
# =========================
CLIENT_TOKEN_ENABLED=true
CLIENT_TOKEN_HEADER=X-Client-Token

# =========================
# 2FA
# =========================
TWO_FACTOR_ENABLED=true
TWO_FACTOR_REQUIRED=true
TWO_FACTOR_API_ENABLED=false
TWO_FACTOR_API_SECRET=

# =========================
# ELECTRON / CLIENT API
# =========================
VIDEO_CLIENT_API_KEY="ALTERAR_PARA_API_KEY_FORTE_DOS_CLIENTES"
VIDEO_CLIENT_ALLOWED_ORIGINS="127.0.0.1,localhost,*.bancomoc.local"









